# ⚙️ Farm2Trade Environment Template
# Duplicate this file to .env and fill in your actual credentials

# --- Database ---
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/farmer_retailer_db
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=your_mysql_password

# --- AI & Intelligence ---
GEMINI_API_KEY=your_gemini_api_key
WEATHER_API_KEY=your_weatherapi_key
LOCATION_API_KEY=your_location_api_key

# --- Security & Auth (Gmail SMTP) ---
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password

# --- Payments (Cashfree) ---
CASHFREE_APP_ID=your_cashfree_app_id
CASHFREE_SECRET_KEY=your_cashfree_secret_key

# --- Frontend & Server ---
VITE_API_URL=http://localhost:8080
PORT=8080
